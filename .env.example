# ---------------------------------------------------------------------------
# Cost Allocations API — environment variable reference
# ---------------------------------------------------------------------------
# Two files are supported:
#
#   .env             — shared defaults, safe to commit (no real secrets here)
#   credentials.env  — local overrides with real secrets, NEVER commit this
#
# To get started locally:
#   copy .env.example credentials.env   (Windows)
#   cp   .env.example credentials.env   (Unix/macOS)
#
# Then edit credentials.env with your actual values.
# Resolution order: env vars > credentials.env > .env > code defaults
# ---------------------------------------------------------------------------

# Required in production — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-long-random-string

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# "development" | "staging" | "production"
APP_ENV=development
